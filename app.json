{
  "expo": {
    "name": "Pokedex-Fleek",
    "slug": "Pokedex-Fleek",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon_pokedex.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon-pokedex.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow $(PRODUCT_NAME) to access your camera"
      },
      "bundleIdentifier": "com.anonymous.PokedexFleek"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-pokedex.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.matudev.pokedexfleek",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "react-native-video",
      [
        "react-native-vision-camera",
        {
          "enableCodeScanner": true,
          "enableMicrophonePermission": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "48249dfc-e43a-4b6c-bb06-0f1ac9742e05"
      }
    }
  }
}